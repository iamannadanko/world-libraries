# Supabase PostgreSQL — pooler (для запитів з додатку)
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — direct (для Prisma міграцій / db push)
DIRECT_URL="postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

PORT=5000

# Supabase Auth
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Admin email — користувач з цим email стає адміністратором
ADMIN_EMAIL="your-admin-email@example.com"
