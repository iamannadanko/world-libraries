// Prisma ORM — підключення до Supabase (PostgreSQL)
// Документація: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Library {
  id              Int              @id @default(autoincrement())
  name            String
  name_en         String?
  country         String
  city            String
  founded         Int?
  collection_size BigInt?
  description     String?
  image_url       String?
  gallery_urls    Json?
  website         String?
  fun_fact        String?
  architecture    String?
  notable_items   String?
  latitude        Float?
  longitude       Float?
  status          String           @default("approved")
  submitted_by    String?
  created_at      DateTime         @default(now())
  favorites       Favorite[]
  delete_requests DeleteRequest[]

  @@map("libraries")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  user_id    String
  library_id Int
  created_at DateTime @default(now())
  library    Library  @relation(fields: [library_id], references: [id], onDelete: Cascade)

  @@unique([user_id, library_id])
  @@map("favorites")
}

model DeleteRequest {
  id         Int      @id @default(autoincrement())
  library_id Int
  user_id    String
  user_email String?
  reason     String?
  status     String   @default("pending")
  created_at DateTime @default(now())
  library    Library  @relation(fields: [library_id], references: [id], onDelete: Cascade)

  @@map("delete_requests")
}
